generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  CHEF
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderSource {
  ZOMATO
  SWIGGY
  WHATSAPP
  DIRECT
}

enum DeliveryPartner {
  ZOMATO
  SWIGGY
  IN_HOUSE
  PICKUP
  OTHER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum KitchenTicketStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InventoryTransactionType {
  PURCHASE_IN
  ORDER_CONSUMPTION
  WASTAGE
  MANUAL_ADJUSTMENT
}

enum ExpenseCategory {
  RAW_MATERIALS
  PACKAGING
  SALARIES
  UTILITIES
  MARKETING
  AGGREGATOR_COMMISSION
  RENT
  MAINTENANCE
  OTHER
}

model Restaurant {
  id    String  @id @default(cuid())
  name  String
  email String  @unique
  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  brands         Brand[]
  categories     MenuCategory[]
  items          MenuItem[]
  tables         RestaurantTable[]
  orders         Order[]
  kitchenTickets KitchenTicket[]
  invoices       Invoice[]
  payments       Payment[]
  expenses       Expense[]

  ingredients           Ingredient[]
  suppliers             Supplier[]
  stockEntries          StockEntry[]
  inventoryTransactions InventoryTransaction[]
  consumptionLogs       ConsumptionLog[]
  auditLogs             AuditLog[]
}

model Brand {
  id String @id @default(cuid())

  name        String
  description String?
  active      Boolean @default(true)

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  menuItems MenuItem[]
  orders    Order[]

  @@index([restaurantId])
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  phone    String? @unique
  password String
  pin      String?

  role Role

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  orders Order[]

  @@index([restaurantId])
}

model MenuCategory {
  id   String @id @default(cuid())
  name String

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  items MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id String @id @default(cuid())

  name        String
  description String?
  price       Float
  available   Boolean @default(true)
  image       String?

  restaurantId String
  categoryId   String
  brandId      String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id])
  category   MenuCategory @relation(fields: [categoryId], references: [id])
  brand      Brand?       @relation(fields: [brandId], references: [id])

  orderItems OrderItem[]
  recipe     Recipe?

  @@index([restaurantId])
  @@index([categoryId])
  @@index([brandId])
}

model RestaurantTable {
  id String @id @default(cuid())

  name     String
  capacity Int
  status   TableStatus @default(AVAILABLE)

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  orders Order[]

  @@index([restaurantId])
}

model Order {
  id String @id @default(cuid())

  orderNumber String      @unique
  type        OrderType   @default(DINE_IN)
  source      OrderSource @default(DIRECT)
  status      OrderStatus @default(PENDING)

  customerName  String?
  customerPhone String?

  deliveryPartner DeliveryPartner?

  totalAmount Float @default(0)

  restaurantId String
  tableId      String?
  createdById  String
  brandId      String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id])
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  createdBy  User             @relation(fields: [createdById], references: [id])
  brand      Brand?           @relation(fields: [brandId], references: [id])

  items           OrderItem[]
  kitchenTicket   KitchenTicket?
  invoice         Invoice?
  consumptionLogs ConsumptionLog[]
  expenses        Expense[]

  @@index([restaurantId])
  @@index([status])
  @@index([source])
  @@index([brandId])
}

model OrderItem {
  id String @id @default(cuid())

  quantity Int
  price    Float
  subtotal Float

  orderId    String
  menuItemId String

  createdAt DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model KitchenTicket {
  id String @id @default(cuid())

  ticketNumber String              @unique
  status       KitchenTicketStatus @default(PENDING)
  notes        String?

  slaMinutes Int?
  startedAt  DateTime?
  readyAt    DateTime?

  restaurantId String
  orderId      String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  order      Order      @relation(fields: [orderId], references: [id])

  @@index([restaurantId])
}

model Invoice {
  id String @id @default(cuid())

  invoiceNumber String @unique

  subtotal    Float
  taxAmount   Float @default(0)
  discount    Float @default(0)
  totalAmount Float

  status InvoiceStatus @default(UNPAID)

  restaurantId String
  orderId      String @unique

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  order      Order      @relation(fields: [orderId], references: [id])

  payments Payment[]

  @@index([restaurantId])
}

model Payment {
  id String @id @default(cuid())

  amount Float

  method PaymentMethod
  status PaymentStatus @default(COMPLETED)

  reference String?

  restaurantId String
  invoiceId    String

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  invoice    Invoice    @relation(fields: [invoiceId], references: [id])

  @@index([restaurantId])
}

model Expense {
  id String @id @default(cuid())

  category ExpenseCategory
  amount   Float
  date     DateTime        @default(now())

  recurring Boolean @default(false)
  notes     String?

  linkedOrderId String?
  restaurantId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  linkedOrder Order?     @relation(fields: [linkedOrderId], references: [id])

  @@index([restaurantId])
  @@index([category])
  @@index([linkedOrderId])
}

model Ingredient {
  id String @id @default(cuid())

  name String
  unit String

  currentStock Float @default(0)
  minimumStock Float @default(0)
  costPerUnit  Float @default(0)

  restaurantId String

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  stockEntries          StockEntry[]
  recipeIngredients     RecipeIngredient[]
  inventoryTransactions InventoryTransaction[]
  consumptionLogs       ConsumptionLog[]

  @@index([restaurantId])
}

model Supplier {
  id String @id @default(cuid())

  name  String
  phone String?
  email String?

  restaurantId String

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  stockEntries StockEntry[]

  @@index([restaurantId])
}

model StockEntry {
  id String @id @default(cuid())

  ingredientId String

  quantity Float
  price    Float

  supplierId   String?
  restaurantId String

  createdAt DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  supplier   Supplier?  @relation(fields: [supplierId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([ingredientId])
  @@index([restaurantId])
}

model Recipe {
  id String @id @default(cuid())

  menuItemId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id String @id @default(cuid())

  recipeId     String
  ingredientId String

  quantity    Float
  costPerUnit Float?

  createdAt DateTime @default(now())

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([recipeId])
  @@index([ingredientId])
}

model InventoryTransaction {
  id String @id @default(cuid())

  ingredientId String

  type InventoryTransactionType

  quantity      Float
  previousStock Float
  newStock      Float

  referenceId String?
  notes       String?

  restaurantId String

  createdAt DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([ingredientId])
  @@index([restaurantId])
  @@index([type])
}

model ConsumptionLog {
  id String @id @default(cuid())

  ingredientId String
  orderId      String?

  quantity Float

  restaurantId String

  createdAt DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([ingredientId])
  @@index([restaurantId])
}

model AuditLog {
  id String @id @default(cuid())

  action   String
  entity   String
  entityId String

  userId       String?
  restaurantId String

  metadata Json?

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}
