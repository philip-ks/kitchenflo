generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  CHEF
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum KitchenTicketStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InventoryTransactionType {
  PURCHASE_IN
  ORDER_CONSUMPTION
  WASTAGE
  MANUAL_ADJUSTMENT
}

model Restaurant {
  id    String  @id @default(cuid())
  name  String
  email String  @unique
  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     MenuCategory[]
  items          MenuItem[]
  tables         RestaurantTable[]
  orders         Order[]
  kitchenTickets KitchenTicket[]
  invoices       Invoice[]
  payments       Payment[]

  ingredients           Ingredient[]
  suppliers             Supplier[]
  stockEntries          StockEntry[]
  inventoryTransactions InventoryTransaction[]
  consumptionLogs       ConsumptionLog[]
  auditLogs             AuditLog[]
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  phone    String? @unique
  password String

  role Role

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  orders Order[]

  @@index([restaurantId])
}

model MenuCategory {
  id   String @id @default(cuid())
  name String

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  items MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id String @id @default(cuid())

  name        String
  description String?
  price       Float
  available   Boolean @default(true)
  image       String?

  restaurantId String
  categoryId   String

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  category   MenuCategory @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]
  recipe     Recipe?

  @@index([restaurantId])
  @@index([categoryId])
}

model RestaurantTable {
  id String @id @default(cuid())

  name     String
  capacity Int
  status   TableStatus @default(AVAILABLE)

  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  orders Order[]

  @@index([restaurantId])
}

model Order {
  id String @id @default(cuid())

  orderNumber String @unique
  type        OrderType   @default(DINE_IN)
  status      OrderStatus @default(PENDING)

  totalAmount Float @default(0)

  restaurantId String
  tableId      String?
  createdById  String

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id])
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  createdBy  User             @relation(fields: [createdById], references: [id])

  items           OrderItem[]
  kitchenTicket   KitchenTicket?
  invoice         Invoice?
  consumptionLogs ConsumptionLog[]

  @@index([restaurantId])
  @@index([status])
}

model OrderItem {
  id String @id @default(cuid())

  quantity Int
  price    Float
  subtotal Float

  orderId    String
  menuItemId String

  createdAt DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model KitchenTicket {
  id String @id @default(cuid())

  ticketNumber String              @unique
  status       KitchenTicketStatus @default(PENDING)
  notes        String?

  restaurantId String
  orderId      String @unique

  createdAt DateTime @generator client {
