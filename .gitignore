cat > .gitignore <<'EOF'
# dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# environment files
.env
.env.*
backend/.env
frontend/.env

# build output
dist/
backend/dist/
frontend/.next/
frontend/out/

# local database files
*.db
*.db-journal
*.sqlite
*.sqlite3
backend/prisma/dev.db

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor
.DS_Store
Thumbs.db
.vscode/
EOF